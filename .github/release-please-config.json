{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "release-type": "rust",
  "include-component-in-tag": false,
  "bump-minor-pre-major": true,
  "bump-patch-for-minor-pre-major": true,
  "plugins": [
    {
      "type": "cargo-workspace",
      "merge": false
    },
    {
      "type": "linked-versions",
      "groupName": "iced_ui workspace",
      "components": ["iced_ui", "demo", "iced_ui_tests"]
    }
  ],
  "packages": {
    "crates/iced_ui": {
      "package-name": "iced_ui",
      "component": "iced_ui"
    },
    "crates/demo": {
      "package-name": "demo",
      "component": "demo",
      "skip-github-release": true
    },
    "crates/iced_ui_tests": {
      "package-name": "iced_ui_tests",
      "component": "iced_ui_tests",
      "skip-github-release": true
    }
  }
}
